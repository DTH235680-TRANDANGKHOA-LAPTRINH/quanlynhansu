<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Thêm tài khoản</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/taikhoan' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Thêm tài khoản' }) %>
            <div class="card card-custom mb-4">
                <div class="card-body">
                    <form action="/taikhoan/them" method="POST" class="needs-validation" novalidate>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Tên đăng nhập</label>
                                <input name="TenDangNhap" type="text" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input name="Email" type="email" class="form-control" placeholder="example@company.com" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mật khẩu</label>
                                <input name="MatKhau" type="password" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Quyền</label>
                                <select name="QuyenHan" class="form-select">
                                    <option value="admin">Admin</option>
                                    <option value="hr">HR</option>
                                    <option value="ketoan">Kế toán</option>
                                    <option value="nhanvien">Nhân viên</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Khóa tài khoản</label>
                                <select name="KichHoat" class="form-select">
                                    <option value="1">Kích hoạt</option>
                                    <option value="0">Khóa</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nhân viên liên kết</label>
                                <select name="NhanVien" class="form-select">
                                    <option value="">Không chọn</option>
                                    <% nhanViens.forEach(nv => { %>
                                        <option value="<%= nv._id %>"><%= nv.TenNV %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">Lưu tài khoản</button>
                            <a href="/taikhoan" class="btn btn-outline-secondary ms-2">Huỷ</a>
                        </div>
                    </form>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
