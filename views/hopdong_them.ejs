<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Thêm hợp đồng</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/hopdong' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Thêm hợp đồng' }) %>
            <div class="card card-custom mb-4">
                <div class="card-body">
                    <h5 class="mb-3">Tạo hợp đồng mới</h5>
                    <form action="/hopdong/them" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nhân viên</label>
                                <select class="form-select" name="NhanVien" required>
                                    <option value="">Chọn nhân viên</option>
                                    <% employees.forEach(emp => { %>
                                        <option value="<%= emp._id %>"><%= emp.TenNV %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Loại hợp đồng</label>
                                <select class="form-select" name="LoaiHD" required>
                                    <option value="Chính thức">Chính thức</option>
                                    <option value="Thử việc">Thử việc</option>
                                    <option value="1 Năm">1 Năm</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ngày bắt đầu</label>
                                <input type="date" name="NgayBatDau" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ngày kết thúc</label>
                                <input type="date" name="NgayKetThuc" class="form-control" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Lương thỏa thuận</label>
                                <input type="number" name="LuongThoaThuan" class="form-control" value="0" required />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button class="btn btn-primary">Lưu hợp đồng</button>
                            <a href="/hopdong" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
