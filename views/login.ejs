<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>Đăng nhập</title>
    <style>
        body {
            background: linear-gradient(180deg, #eef5ff 0%, #ffffff 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Inter", sans-serif;
        }
        .login-card {
            max-width: 420px;
            width: 100%;
            border: none;
            border-radius: 24px;
            box-shadow: 0 25px 60px rgba(35, 60, 110, 0.12);
            overflow: hidden;
        }
        .login-card .card-header {
            background: #1f3d8f;
            color: #fff;
            padding: 2rem 2rem 1.5rem;
        }
        .login-card .card-body {
            padding: 2rem;
        }
        .login-card .form-control {
            border-radius: 12px;
            padding: 1rem 1rem;
        }
        .login-card .btn-primary {
            border-radius: 12px;
            padding: 0.95rem 1.3rem;
            font-weight: 600;
        }
        .login-footer {
            font-size: 0.9rem;
            color: #6f7c98;
            margin-top: 1rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card login-card shadow-sm">
        <div class="card-header text-center">
            <h2 class="mb-1">Hệ thống nhân sự</h2>
            <p class="mb-0">Chào mừng bạn đến với hệ thống</p>
        </div>
        <div class="card-body">
            <div class="text-center mb-4">
                <p>Đăng nhập bằng Gmail admin hoặc tài khoản hệ thống.</p>
            </div>
            <% if (message) { %>
                <div class="alert alert-danger py-2"><%= message %></div>
            <% } %>
            <form action="/login" method="POST" class="mb-3">
                <div class="mb-3 text-start">
                    <label class="form-label">Tên đăng nhập</label>
                    <input name="username" type="text" class="form-control" placeholder="Nhập tên đăng nhập" required />
                </div>
                <div class="mb-3 text-start">
                    <label class="form-label">Mật khẩu</label>
                    <input name="password" type="password" class="form-control" placeholder="Nhập mật khẩu" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-3">Đăng nhập bằng mật khẩu</button>
            </form>
            <div class="d-flex align-items-center gap-2 mb-3">
                <hr class="flex-grow-1" />
                <span class="text-muted">Hoặc</span>
                <hr class="flex-grow-1" />
            </div>
            <div class="d-grid gap-2">
                <a href="/auth/google" class="btn btn-danger btn-lg">
                    <i class="bi bi-google me-2"></i> Đăng nhập bằng Gmail
                </a>
            </div>
            <div class="login-footer mt-4">
                Sử dụng Gmail admin hoặc tài khoản hệ thống để truy cập.
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
