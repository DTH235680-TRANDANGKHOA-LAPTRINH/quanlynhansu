<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Danh sách nhân sự</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/nhansu' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Danh sách nhân sự' }) %>

            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
                <form class="search-bar d-flex gap-2 flex-fill" action="/nhansu" method="GET">
                    <input type="text" name="q" placeholder="Tìm kiếm theo tên, mã NV, số điện thoại" value="<%= filters.q || '' %>" class="form-control" />
                    <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                </form>
                <div class="d-flex gap-2 flex-wrap">
                    <% if (['admin', 'hr'].includes(user?.QuyenHan)) { %>
                        <a href="/nhansu/them" class="btn btn-success"><i class="bi bi-plus-lg"></i> Thêm nhân viên mới</a>
                    <% } %>
                </div>
            </div>

            <form id="filterForm" action="/nhansu" method="GET">
                <input type="hidden" name="q" value="<%= filters.q || '' %>" />
            </form>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label class="form-label small mb-1">Phòng ban</label>
                    <select name="phongban" form="filterForm" class="form-select" onchange="document.getElementById('filterForm').submit();">
                        <option value="">Tất cả phòng ban</option>
                        <% phongBans.forEach(pb => { %>
                            <option value="<%= pb._id %>" <%= filters.phongban === pb._id.toString() ? 'selected' : '' %>><%= pb.TenPB %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small mb-1">Chức vụ</label>
                    <select name="chucvu" form="filterForm" class="form-select" onchange="document.getElementById('filterForm').submit();">
                        <option value="">Tất cả chức vụ</option>
                        <% chucVus.forEach(cv => { %>
                            <option value="<%= cv._id %>" <%= filters.chucvu === cv._id.toString() ? 'selected' : '' %>><%= cv.TenCV %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small mb-1">Trạng thái</label>
                    <select name="trangthai" form="filterForm" class="form-select" onchange="document.getElementById('filterForm').submit();">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Đang làm việc" <%= filters.trangthai === 'Đang làm việc' ? 'selected' : '' %>>Đang làm việc</option>
                        <option value="Đã nghỉ việc" <%= filters.trangthai === 'Đã nghỉ việc' ? 'selected' : '' %>>Đã nghỉ việc</option>
                    </select>
                </div>
            </div>

            <div class="employee-grid row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                <% if (!nhanViens.length) { %>
                    <div class="col-12">
                        <div class="card card-custom p-4 text-center">
                            <p class="mb-0">Không tìm thấy nhân viên phù hợp.</p>
                        </div>
                    </div>
                <% } %>
                <% nhanViens.forEach(nv => { %>
                    <div class="col">
                        <a href="/nhansu/<%= nv._id %>" class="employee-card text-decoration-none text-body">
                            <div class="card card-custom h-100 shadow-sm">
                                <div class="card-body d-flex flex-column gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="<%= (nv.HinhAnh && nv.HinhAnh !== 'no-image.jpg') ? (nv.HinhAnh.startsWith('/') ? nv.HinhAnh : '/' + nv.HinhAnh) : 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" alt="Avatar" class="employee-avatar" />
                                        <div>
                                            <h5 class="mb-1"><%= nv.TenNV %></h5>
                                            <div class="text-muted small"><%= nv.ChucVu?.TenCV || 'Chưa có chức vụ' %></div>
                                            <div class="text-muted small"><%= nv.PhongBan?.TenPB || 'Chưa có phòng ban' %></div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-<%= nv.TrangThai === 'Đã nghỉ việc' ? 'danger' : 'success' %>">
                                                <i class="bi bi-circle-fill me-1"></i> <%= nv.TrangThai || 'Đang làm việc' %>
                                            </span>
                                        </div>
                                        <div class="text-end small text-muted">
                                            <div>ID: <%= nv._id.toString().slice(-6) %></div>
                                            <div><i class="bi bi-telephone"></i> <%= nv.DienThoai || '-' %></div>
                                            <div><i class="bi bi-envelope"></i> <%= nv.TaiKhoanEmail || '-' %></div>
                                        </div>
                                    </div>
                                    <div class="mt-auto">
                                        <span class="badge badge-action">Xem chi tiết <i class="bi bi-chevron-right"></i></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>

            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>