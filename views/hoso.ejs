<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Hồ sơ của tôi</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/hoso' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Hồ sơ của tôi' }) %>
            <% if (me) { %>
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card card-custom p-4 text-center">
                            <img src="<%= (me.HinhAnh && me.HinhAnh !== 'no-image.jpg') ? (me.HinhAnh.startsWith('/') ? me.HinhAnh : '/' + me.HinhAnh) : 'https://cdn-icons-png.flaticon.com/512/149/149071.png' %>" class="employee-avatar-lg mb-3" alt="Avatar" />
                            <h4><%= me.TenNV %></h4>
                            <p class="text-muted mb-3"><%= me.ChucVu?.TenCV || 'Chưa có chức vụ' %> - <%= me.PhongBan?.TenPB || 'Chưa có phòng ban' %></p>
                            <p class="mb-1"><strong>Trạng thái:</strong> <%= me.TrangThai || 'Đang làm việc' %></p>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card card-custom p-4">
                            <h5>Thông tin cá nhân</h5>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6"><strong>Ngày sinh:</strong> <%= me.NgaySinh ? me.NgaySinh.toISOString().slice(0, 10) : '-' %></div>
                                <div class="col-md-6"><strong>Giới tính:</strong> <%= me.GioiTinh || '-' %></div>
                                <div class="col-md-6"><strong>Số điện thoại:</strong> <%= me.DienThoai || '-' %></div>
                                <div class="col-md-6"><strong>Địa chỉ:</strong> <%= me.DiaChi || '-' %></div>
                                <div class="col-md-6"><strong>Số người phụ thuộc:</strong> <%= me.SoNguoiPhuThuoc || 0 %></div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="card card-custom mb-4">
                    <div class="card-body">
                        <h5 class="mb-3">Danh sách hồ sơ</h5>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Nhân viên</th>
                                        <th>Phòng ban</th>
                                        <th>Chức vụ</th>
                                        <th>Trạng thái</th>
                                        <th>Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (!employees.length) { %>
                                        <tr><td colspan="5" class="text-center">Chưa có hồ sơ.</td></tr>
                                    <% } %>
                                    <% employees.forEach(emp => { %>
                                        <tr>
                                            <td><%= emp.TenNV %></td>
                                            <td><%= emp.PhongBan?.TenPB || '-' %></td>
                                            <td><%= emp.ChucVu?.TenCV || '-' %></td>
                                            <td><%= emp.TrangThai || 'Đang làm việc' %></td>
                                            <td><a href="/nhansu/<%= emp._id %>" class="btn btn-sm btn-outline-primary">Xem</a></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            <% } %>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>