<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title><%= title %></title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Tổng quan' }) %>

            <div class="grid-cols-2 mb-4">
                <div class="card card-custom">
                    <div class="card-body stat-card">
                        <div class="info">
                            <span>Tổng số nhân viên</span>
                            <div class="value"><%= totalNhanVien %></div>
                        </div>
                        <i class="bi bi-people-fill fs-1 text-primary"></i>
                    </div>
                </div>
                <div class="card card-custom">
                    <div class="card-body stat-card">
                        <div class="info">
                            <span>Đang làm hôm nay</span>
                            <div class="value"><%= activeNhanVien %></div>
                        </div>
                        <i class="bi bi-check-circle-fill fs-1 text-success"></i>
                    </div>
                </div>
                <div class="card card-custom">
                    <div class="card-body stat-card">
                        <div class="info">
                            <span>Quỹ lương dự kiến</span>
                            <div class="value">1.8 tỷ VNĐ</div>
                        </div>
                        <i class="bi bi-currency-dollar fs-1 text-warning"></i>
                    </div>
                </div>
                <div class="card card-custom">
                    <div class="card-body stat-card">
                        <div class="info">
                            <span>Đánh giá KPI mới</span>
                            <div class="value">15 bản</div>
                        </div>
                        <i class="bi bi-exclamation-triangle-fill fs-1 text-danger"></i>
                    </div>
                </div>
            </div>

            <div class="grid-cols-2 gap-4">
                <div class="card card-custom">
                    <div class="card-body">
                        <h5>Phân bổ nhân sự theo phòng ban</h5>
                        <div class="chart-placeholder">Biểu đồ cột mẫu</div>
                    </div>
                </div>
                <div class="card card-custom">
                    <div class="card-body">
                        <h5>Trạng thái chấm công hôm nay</h5>
                        <div class="chart-placeholder">Biểu đồ tròn mẫu</div>
                    </div>
                </div>
            </div>

            <div class="grid-cols-2 mt-4 gap-4">
                <div class="card card-custom">
                    <div class="card-body">
                        <h5>Danh sách chờ phê duyệt</h5>
                        <div class="notice-card">
                            <div class="item">
                                <div>
                                    <strong>Trần Văn B</strong>
                                    <small>Kỹ thuật - Xin nghỉ phép</small>
                                </div>
                                <div><span class="badge-action">Duyệt</span></div>
                            </div>
                            <div class="item">
                                <div>
                                    <strong>Trần Thị C</strong>
                                    <small>HR - KPI</small>
                                </div>
                                <div><span class="badge-action">Duyệt</span></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card card-custom">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5>Cảnh báo hợp đồng</h5>
                            <span class="badge badge-expire">Sớm hết hạn</span>
                        </div>
                        <div class="notice-card">
                            <div class="item">
                                <div>
                                    <strong>Lê Thị B - Sales</strong>
                                    <small>2026-10-30</small>
                                </div>
                                <span class="badge-action">Tái ký</span>
                            </div>
                            <div class="item">
                                <div>
                                    <strong>Đỗ Thị D - Kế toán</strong>
                                    <small>2026-10-30</small>
                                </div>
                                <span class="badge-action">Tái ký</span>
                            </div>
                            <div class="item">
                                <div>
                                    <strong>Hoàng Văn E - HR</strong>
                                    <small>2026-07-01</small>
                                </div>
                                <span class="badge-action">Tái ký</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('footer') %>
        </main>
    </div>
    <%- include('javascript') %>
</body>
</html>