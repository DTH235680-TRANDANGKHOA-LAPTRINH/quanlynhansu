<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Thêm bảng lương</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/luong' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Thêm bảng lương' }) %>
            <div class="card card-custom mb-4">
                <div class="card-body">
                    <h5 class="mb-3"><%= record ? 'Chỉnh sửa bảng lương' : 'Thêm bảng lương mới' %></h5>
                    <form action="<%= record ? '/luong/sua/' + record._id : '/luong/them' %>" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nhân viên</label>
                                <select name="NhanVien" class="form-select" required>
                                    <option value="">Chọn nhân viên</option>
                                    <% employees.forEach(emp => { %>
                                        <option value="<%= emp._id %>" <%= record && record.NhanVien && record.NhanVien._id.toString() === emp._id.toString() ? 'selected' : '' %>><%= emp.TenNV %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tháng</label>
                                <% if (record) { %>
                                    <input type="text" class="form-control" value="<%= record.Thang %>" disabled />
                                    <input type="hidden" name="Thang" value="<%= record.Thang %>" />
                                <% } else { %>
                                    <input name="Thang" type="number" class="form-control" min="1" max="12" value="<%= new Date().getMonth() + 1 %>" required />
                                <% } %>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Năm</label>
                                <% if (record) { %>
                                    <input type="text" class="form-control" value="<%= record.Nam %>" disabled />
                                    <input type="hidden" name="Nam" value="<%= record.Nam %>" />
                                <% } else { %>
                                    <input name="Nam" type="number" class="form-control" value="<%= new Date().getFullYear() %>" required />
                                <% } %>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Lương cơ bản</label>
                                <input name="LuongCoBan" type="number" class="form-control" value="<%= record ? record.LuongCoBan : '' %>" required />
                                <% if (record) { %>
                                    <small class="text-muted">Sửa lương cơ bản cũng sẽ cập nhật lương thỏa thuận trong hợp đồng nhân viên.</small>
                                <% } %>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Lương OT</label>
                                <input name="LuongOT" type="number" class="form-control" value="<%= record ? record.LuongOT : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phụ cấp chức vụ</label>
                                <input name="PhuCapChucVu" type="number" class="form-control" value="<%= record ? record.PhuCapChucVu : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phụ cấp khu vực</label>
                                <input name="PhuCapKhuVuc" type="number" class="form-control" value="<%= record ? record.PhuCapKhuVuc : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Thưởng KPI</label>
                                <input name="ThuongKPI" type="number" class="form-control" value="<%= record ? record.ThuongKPI : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Thưởng chuyên cần</label>
                                <input name="ThuongChuyenCan" type="number" class="form-control" value="<%= record ? record.ThuongChuyenCan : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phụ cấp ăn trưa</label>
                                <input name="PhuCapAnTrua" type="number" class="form-control" value="<%= record ? record.PhuCapAnTrua : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Trợ cấp phúc lợi</label>
                                <input name="TroCapPhucLoi" type="number" class="form-control" value="<%= record ? record.TroCapPhucLoi : '0' %>" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Thuế TNCN</label>
                                <input type="text" class="form-control" value="<%= record ? record.ThueTNCN.toLocaleString('vi-VN') : 'Tự động' %> ₫" disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Giảm trừ khác</label>
                                <input name="GiamTruKhac" type="number" class="form-control" value="<%= record ? record.GiamTruKhac : '0' %>" />
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button class="btn btn-primary"><%= record ? 'Cập nhật bảng lương' : 'Lưu bảng lương' %></button>
                            <a href="/luong" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
