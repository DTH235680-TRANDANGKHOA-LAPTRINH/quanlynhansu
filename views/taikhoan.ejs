<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Danh sách tài khoản</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/taikhoan' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Danh sách tài khoản' }) %>
            <div class="card card-custom mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="mb-1">Danh sách tài khoản</h5>
                            <p class="text-muted mb-0">Quản lý tài khoản hệ thống, mật khẩu và phân quyền. Tài khoản cũ không có mật khẩu gốc sẽ hiện thông báo và cần sửa lại.</p>
                        </div>
                        <a href="/taikhoan/them" class="btn btn-primary">Thêm tài khoản</a>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Tên đăng nhập</th>
                                    <th>Email</th>
                                    <th>Mật khẩu</th>
                                    <th>Quyền</th>
                                    <th>Trạng thái</th>
                                    <th>Nhân viên</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% taiKhoans.forEach(tk => { %>
                                    <tr>
                                        <td><%= tk.TenDangNhap %></td>
                                        <td><%= tk.Email || '-' %></td>
                                        <td>
                                            <% if (tk.MatKhauPlain) { %>
                                                <%= tk.MatKhauPlain %>
                                            <% } else if (tk.MatKhau && /^\$2[aby]\$/.test(tk.MatKhau)) { %>
                                                Đã mã hóa
                                            <% } else if (tk.MatKhau) { %>
                                                <%= tk.MatKhau %>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= tk.QuyenHan %></td>
                                        <td><%= tk.KichHoat === 1 ? 'Kích hoạt' : 'Khoá' %></td>
                                        <td><%= tk.NhanVien ? tk.NhanVien.TenNV : '-' %></td>
                                        <td>
                                            <a href="/taikhoan/sua/<%= tk._id %>" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
