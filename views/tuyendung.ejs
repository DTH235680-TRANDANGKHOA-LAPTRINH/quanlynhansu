<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Tuyển dụng</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/tuyendung' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Tuyển dụng' }) %>
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
                <div>
                    <h4 class="mb-1">Tuyển dụng & onboarding</h4>
                    <p class="text-muted mb-0">Thêm nhân sự mới và đồng bộ sang Nhân sự, Hợp đồng, Tài khoản.</p>
                </div>
                <a href="/nhansu/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm nhân sự</a>
            </div>

            <div class="card card-custom mb-4">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Nhân viên</th>
                                    <th>Phòng ban</th>
                                    <th>Chức vụ</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!employees.length) { %>
                                    <tr><td colspan="5" class="text-center">Chưa có nhân sự.</td></tr>
                                <% } %>
                                <% employees.forEach(emp => { %>
                                    <tr>
                                        <td><%= emp.TenNV %></td>
                                        <td><%= emp.PhongBan?.TenPB || '-' %></td>
                                        <td><%= emp.ChucVu?.TenCV || '-' %></td>
                                        <td><%= emp.TrangThai || 'Đang làm việc' %></td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a href="/nhansu/sua/<%= emp._id %>" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                                <form action="/tuyendung/xoa/<%= emp._id %>" method="POST" onsubmit="return confirm('Xóa nhân sự khỏi tuyển dụng?');">
                                                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>