<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Lương & Thưởng</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/luong' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Lương & Thưởng' }) %>
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
                <div>
                    <h4 class="mb-1">Bảng lương & thưởng</h4>
                    <p class="text-muted mb-0">Xem toàn bộ bảng lương, tổng tiền trả và các khoản thưởng của nhân viên.</p>
                </div>
                <% if (canEdit) { %>
                    <a href="/luong/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm bảng lương</a>
                <% } %>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card card-custom p-4">
                        <h6>Tổng quỹ lương</h6>
                        <p class="display-6 mb-0"><%= totals.totalPayroll.toLocaleString('vi-VN') %> ₫</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-custom p-4">
                        <h6>Tổng thưởng KPI / Chuyên cần</h6>
                        <p class="display-6 mb-0"><%= totals.totalReward.toLocaleString('vi-VN') %> ₫</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-custom p-4">
                        <h6>Tổng khấu trừ</h6>
                        <p class="display-6 mb-0"><%= totals.totalDeduction.toLocaleString('vi-VN') %> ₫</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card card-custom p-4">
                        <h6>Tổng thực lĩnh</h6>
                        <p class="display-6 mb-0"><%= totals.totalNet.toLocaleString('vi-VN') %> ₫</p>
                    </div>
                </div>
            </div>

            <div class="card card-custom mb-4">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th rowspan="2">Nhân viên</th>
                                    <th rowspan="2">Tháng/Năm</th>
                                    <th rowspan="2" class="text-end">Lương cơ bản</th>
                                    <th colspan="3" class="text-center">Phụ cấp</th>
                                    <th colspan="2" class="text-center">Thưởng</th>
                                    <th colspan="2" class="text-center">Phụ cấp khác</th>
                                    <th rowspan="2" class="text-end">Tổng thu nhập</th>
                                    <th colspan="3" class="text-center">Bảo hiểm</th>
                                    <th colspan="2" class="text-center">Thuế / Giảm trừ</th>
                                    <th colspan="2" class="text-center">Tổng</th>
                                    <% if (canEdit) { %><th rowspan="2">Hành động</th><% } %>
                                </tr>
                                <tr>
                                    <th class="text-end">Chức vụ</th>
                                    <th class="text-end">Khu vực</th>
                                    <th class="text-end">OT</th>
                                    <th class="text-end">KPI</th>
                                    <th class="text-end">Chuyên cần</th>
                                    <th class="text-end">Ăn trưa</th>
                                    <th class="text-end">Phúc lợi</th>
                                    <th class="text-end">BHXH</th>
                                    <th class="text-end">BHYT</th>
                                    <th class="text-end">BHTN</th>
                                    <th class="text-end">Thuế TNCN</th>
                                    <th class="text-end">Giảm trừ khác</th>
                                    <th class="text-end">Tổng khấu trừ</th>
                                    <th class="text-end">Thực lĩnh</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!luongRecords.length) { %>
                                    <tr><td colspan="<%= canEdit ? 19 : 18 %>" class="text-center">Chưa có dữ liệu lương.</td></tr>
                                <% } %>
                                <% luongRecords.forEach(record => { %>
                                    <tr>
                                        <td><%= record.NhanVien?.TenNV || 'Không rõ' %></td>
                                        <td><%= record.Thang %>/<%= record.Nam %></td>
                                        <td class="text-end"><%= record.LuongCoBan?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.PhuCapChucVu?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.PhuCapKhuVuc?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.LuongOT?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.ThuongKPI?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.ThuongChuyenCan?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.PhuCapAnTrua?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.TroCapPhucLoi?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.TongThuNhap?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.BHXH?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.BHYT?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.BHTN?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.ThueTNCN?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.GiamTruKhac?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.TongKhauTru?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <td class="text-end"><%= record.LuongThucLinh?.toLocaleString('vi-VN') || 0 %> ₫</td>
                                        <% if (canEdit) { %>
                                            <td>
                                                <div class="d-flex gap-2 flex-wrap">
                                                    <a href="/luong/sua/<%= record._id %>" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                                    <form action="/luong/xoa/<%= record._id %>" method="POST" class="m-0" onsubmit="return confirm('Xóa bảng lương này?');">
                                                        <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                                    </form>
                                                </div>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>