<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Thêm nhân viên mới</title>
</head>
<body>
    <div class="app-shell">
        <%- include('partials/sidebar', { menuItems, currentPath: '/nhansu' }) %>
        <main class="main-content">
            <%- include('partials/topbar', { user: user, pageTitle: 'Onboarding nhân viên mới' }) %>

            <div class="card card-custom mb-4">
                <div class="card-body">
                    <h5 class="mb-3">Thông tin nhân viên</h5>
                    <form action="/nhansu/them" method="POST" enctype="multipart/form-data">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">Tên đầy đủ</label>
                                <input name="TenNV" type="text" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input name="DienThoai" type="text" class="form-control" required pattern="[0-9]{10}" title="Số điện thoại phải là 10 chữ số" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Gmail</label>
                                <input name="Gmail" type="email" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tên đăng nhập</label>
                                <input name="TenDangNhap" type="text" class="form-control" placeholder="Tên đăng nhập hệ thống" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mật khẩu</label>
                                <input name="MatKhau" type="password" class="form-control" placeholder="Mật khẩu" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Năm sinh</label>
                                <input name="NgaySinh" type="number" class="form-control" min="1900" max="2100" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Giới tính</label>
                                <select name="GioiTinh" class="form-select">
                                    <option value="">Chọn giới tính</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Số người phụ thuộc</label>
                                <input name="SoNguoiPhuThuoc" type="number" class="form-control" min="0" value="0" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Địa chỉ</label>
                                <textarea name="DiaChi" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phòng ban</label>
                                <select name="PhongBan" class="form-select" required>
                                    <option value="">Chọn phòng ban</option>
                                    <% phongBans.forEach(pb => { %>
                                        <option value="<%= pb._id %>"><%= pb.TenPB %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Chức vụ</label>
                                <select name="ChucVu" class="form-select" required>
                                    <option value="">Chọn chức vụ</option>
                                    <% chucVus.forEach(cv => { %>
                                        <option value="<%= cv._id %>"><%= cv.TenCV %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Loại hợp đồng</label>
                                <select name="LoaiHD" class="form-select">
                                    <option value="Chính thức">Chính thức</option>
                                    <option value="Thử việc">Thử việc</option>
                                    <option value="1 Năm">1 Năm</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ngày bắt đầu</label>
                                <input name="NgayBatDau" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ngày kết thúc</label>
                                <input name="NgayKetThuc" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Lương thỏa thuận</label>
                                <input name="LuongThoaThuan" type="number" class="form-control" step="1000" min="0" />
                            </div>
                            <% if (uploadEnabled) { %>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Ảnh thẻ</label>
                                    <input name="HinhAnh" type="file" class="form-control" accept="image/*" />
                                </div>
                            <% } %>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Lưu nhân viên</button>
                            <a href="/nhansu" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
            <%- include('footer') %>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
